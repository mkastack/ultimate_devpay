# ── Supabase ─────────────────────────────────────────────────────────────────
# Get these from: https://supabase.com/dashboard → your project → Settings → API
VITE_SUPABASE_URL=https://your-project.supabase.co
SUPABASE_URL=https://your-project.supabase.co

VITE_SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_ANON_KEY=your-supabase-anon-key

# ── Resend (Email) ────────────────────────────────────────────────────────────
# Get from: https://resend.com/api-keys
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxx
VITE_RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── Sentry (Error Monitoring) ─────────────────────────────────────────────────
# Get from: https://sentry.io → your project → Settings → SDK Setup
VITE_SENTRY_DSN=https://xxxxxxxx@xxxxxxxx.ingest.sentry.io/xxxxxxxx
SENTRY_DSN=https://xxxxxxxx@xxxxxxxx.ingest.sentry.io/xxxxxxxx
SENTRY_ORG=your-sentry-org
SENTRY_PROJECT=your-sentry-project
SENTRY_AUTH_TOKEN=your-sentry-auth-token

# ── Inngest (Background Jobs) ─────────────────────────────────────────────────
# Get from: https://app.inngest.com → your app → Manage → Keys
VITE_INNGEST_EVENT_KEY=your-inngest-event-key
INNGEST_SIGNING_KEY=your-inngest-signing-key

# ── Paystack (Payments) ───────────────────────────────────────────────────────
# Get from: https://dashboard.paystack.com/#/settings/developer
VITE_PAYSTACK_PUBLIC_KEY=your-paystack-public-key
PAYSTACK_SECRET_KEY=your-paystack-secret-key

# ── Cloudinary (Image uploads) ────────────────────────────────────────────────
# Get from: https://console.cloudinary.com → Dashboard
# CLOUDINARY_URL alone is enough for the Node SDK (cloudinary://key:secret@cloud_name)
CLOUDINARY_URL=cloudinary://your-api-key:your-api-secret@your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret
CLOUDINARY_CLOUD_NAME=your-cloud-name
VITE_CLOUDINARY_CLOUD_NAME=your-cloud-name
